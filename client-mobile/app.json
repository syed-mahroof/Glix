{
  "expo": {
    "name": "Glix",
    "slug": "glix",
    "scheme": "watchtracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.watchtracker.app",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.watchtracker"
        ]
      }
    },
    "android": {
      "package": "com.watchtracker.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "./plugins/withExcludeLegacySupportLibs",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.374430247793-cq07307q5hfs1bri177livsfffqbqhhs"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "WatchlistWidget",
              "label": "Watchlist",
              "description": "Your next-up shows, tap one to jump right in.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "maxResizeWidth": "400dp",
              "maxResizeHeight": "350dp",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "UpcomingWidget",
              "label": "Upcoming",
              "description": "What's airing soon, tap one to jump right in.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "maxResizeWidth": "400dp",
              "maxResizeHeight": "350dp",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.watchtracker",
          "enableAndroid": false,
          "widgets": [
            {
              "name": "Watchlist",
              "displayName": "Watchlist",
              "description": "See the next episode in your watchlist.",
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium"
                ]
              }
            },
            {
              "name": "Upcoming",
              "displayName": "Upcoming",
              "description": "Countdown to the next airing show.",
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium"
                ]
              }
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.watchtracker.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.watchtracker"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "c2fbe23e-0540-421a-b445-e42dcf8b488c"
      }
    },
    "owner": "ogus-gambheera",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c2fbe23e-0540-421a-b445-e42dcf8b488c"
    }
  }
}
